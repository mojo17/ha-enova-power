#!/usr/bin/env bash
# Bootstrap the local dev/test virtualenv.
#
# Creates .venv (gitignored) and installs the test requirements, which pull in
# pytest-homeassistant-custom-component *and* a matching `homeassistant` (with
# the `hass` CLI). So one venv both runs pytest and serves a live dev instance,
# matching CI exactly. Safe to re-run any time to refresh dependencies.
#
# Uses `uv` when available (much faster on HA's large dependency tree, and it can
# fetch Python 3.14 itself); otherwise falls back to stock venv + pip. Either way
# the result is a plain .venv that scripts/develop and scripts/test activate the
# same way.
set -euo pipefail
cd "$(dirname "$0")/.."

# HA 2026.7+ requires Python >=3.14.2. An older interpreter makes the installer
# backtrack to ancient deps with no 3.14 wheels and try to compile from source.
if command -v uv >/dev/null 2>&1; then
  echo "Using uv ($(uv --version))"
  # Downloads a managed CPython 3.14 if the host doesn't already have one.
  uv venv --python 3.14 .venv
  # shellcheck disable=SC1091
  source .venv/bin/activate
  uv pip install -r requirements_test.txt
else
  echo "uv not found — falling back to venv + pip (slower)."
  PYTHON="${PYTHON:-python3.14}"
  if ! command -v "$PYTHON" >/dev/null 2>&1; then
    echo "Python interpreter '$PYTHON' not found." >&2
    echo "Install it ('brew install python@3.14', or 'brew install uv' for the fast path)," >&2
    echo "or set PYTHON=/path/to/python3.14." >&2
    exit 1
  fi
  "$PYTHON" - <<'PY'
import sys
if sys.version_info < (3, 14):
    raise SystemExit(
        f"Home Assistant requires Python >=3.14; got {sys.version.split()[0]}. "
        "Set PYTHON=/path/to/python3.14."
    )
PY
  [ -d .venv ] || "$PYTHON" -m venv .venv
  # shellcheck disable=SC1091
  source .venv/bin/activate
  python -m pip install --upgrade pip wheel
  pip install -r requirements_test.txt
fi

echo
echo "Done. Next:"
echo "  ./scripts/develop   # live HA dev instance on http://localhost:8123"
echo "  ./scripts/test      # run the pytest suite"
